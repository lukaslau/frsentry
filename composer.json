{
  "name": "frento/frsentry",
  "type": "prestashop-module",
  "license": "proprietary",
  "authors": [
    {
      "name": "Frento IT",
      "email": "info@frentoit.com"
    }
  ],
  "repositories": [
    {
      "type": "path",
      "url": "do_not_include/sentry",
      "options": {
        "symlink": false
      }
    }
  ],
  "require": {
    "php": ">=7.2.0",
    "frento/frsentry-scoped": "*",
    "symfony/options-resolver": "^5.4",
    "symfony/deprecation-contracts": "^2.5",
    "psr/log": "^1.0",
    "jean85/pretty-package-versions": "^1.6"
  },
  "require-dev": {
    "sentry/sentry": "^4.8",
    "prestashop/php-dev-tools": "^5.0",
    "friendsofphp/php-cs-fixer": "^3.4"
  },
  "autoload": {
    "psr-4": {
      "Frento\\FrSentry\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "prepend-autoloader": false,
    "platform-check": false
  }
}
